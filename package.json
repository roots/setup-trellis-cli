{
  "name": "setup-trellis-cli",
  "version": "1.3.1",
  "description": "Sets up Trellis CLI for GitHub Action workflows",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "ncc build",
    "prepare": "ncc build -o dist --source-map --license licenses.txt",
    "test": "vitest run",
    "all": "npm run prepare && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roots/setup-trellis-cli.git"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "Roots",
    "WordPress",
    "Trellis"
  ],
  "author": "Scott Walkinshaw <scott@roots.io>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/roots/setup-trellis-cli/issues"
  },
  "homepage": "https://github.com/roots/setup-trellis-cli",
  "dependencies": {
    "@actions/cache": "^6.0.0",
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/glob": "^0.7.0",
    "@actions/http-client": "^4.0.1",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.44.0",
    "vitest": "^4.1.5"
  }
}
